# 클코클라우드 소셜 로그인 설정
NEXT_PUBLIC_SITE_URL=http://localhost:3001
AUTH_SESSION_SECRET=replace-with-a-long-random-secret

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_JAVASCRIPT_KEY=
NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY=

# 클코클라우드 구매/관리자 설정
ADMIN_EMAIL=gimjeonghugimk@gmail.com
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# 관리자 콘솔 (admin-panel) 설정
# OAuth 로그인 후 관리자 진입 후보 이메일 (콤마 구분)
ADMIN_ALLOWED_EMAILS=gimjeonghugimk@gmail.com,support.clcocloud@gmail.com,gimjeonghugim@gmail.com
ADMIN_GATE_PATH=/admin-gate
ADMIN_PANEL_PATH=/admin-panel

# scryptHash() 출력값을 그대로 붙여넣습니다.
# 평문은 .env에 저장하지 마세요. scripts/create-admin-secrets.ts로 생성하세요.
ADMIN_LOGIN_ID_HASH=
ADMIN_PASSWORD_HASH=

ADMIN_SESSION_TTL_MINUTES=60
ADMIN_DATE_CODE_TIMEZONE=Asia/Seoul

# country 헤더를 신뢰할 수 없을 때 fail-closed 여부 (운영: true)
ADMIN_GEO_FAIL_CLOSED=true
# KR 지오 차단을 우회 (로컬 개발 / 해외에서 Vercel 프리뷰 접근 시 true).
# NODE_ENV !== "production"이면 기본 true, 운영 배포에서는 미설정 = false.
# 운영 배포에서 해외 출장 등으로 접근해야 할 때만 ADMIN_GEO_BYPASS=true 로 명시.
ADMIN_GEO_BYPASS=
ADMIN_RATE_LIMIT_MAX_FAILS=5
ADMIN_RATE_LIMIT_LOCK_MINUTES=30

# 32바이트 이상 랜덤 base64. 노출 시 토큰 위조 가능.
ADMIN_COOKIE_SECRET=
ADMIN_CSRF_SECRET=

# AIP 대시보드 엔진 (구독핀 대시보드2.0) 설정
ROUTEAI_PROXY_MODE=direct
ROUTEAI_DIRECT_USAGE_ENDPOINTS=

# direct 조회가 막힐 때 서버에서 우회하여 사용할 옵션 정보
ROUTEAI_AUTH_MODE=login
ROUTEAI_OPERATOR_EMAIL=
ROUTEAI_OPERATOR_PASSWORD=
ROUTEAI_OPERATOR_COOKIE=
ROUTEAI_API_TOKEN=

# 관리자 및 잔액 경고 제어
ADMIN_TOKEN=
ALERT_WEBHOOK_URL=
ADMIN_DASHBOARD_CODE_HASH=
ADMIN_DASHBOARD_ACCESS_CODE=
ADMIN_DASHBOARD_SESSION_SECRET=

# 데이터베이스 연동 및 보안 (선택사항, Ledger 저장용)
ENCRYPTION_KEY=
DATABASE_URL=

# PayApp PG 결제 연동 설정
PAYAPP_USERID=
PAYAPP_LINKKEY=
PAYAPP_LINKVAL=
PAYAPP_VALUE=
PAYAPP_RETURN_URL=https://www.clcocloud.kr/order/success
PAYAPP_FEEDBACK_URL=https://www.clcocloud.kr/api/payapp/webhook
PAYAPP_IP_WHITELIST=

# 바티AI (Bati SEND) 알림톡 웹훅 및 알림 설정
BATI_WEBHOOK_PAY_DONE=
BATI_WEBHOOK_ADMIN_PAID=
BATI_WEBHOOK_ADMIN_LOW_STOCK=
BATI_TIMEOUT_MS=8000
ADMIN_PHONE=
OPERATOR_PHONE=01058503625

# API 키 자판기 (Vending) 모듈 설정
# - LOW_STOCK_THRESHOLD: 가용 키 수가 이 값 이하면 대시보드에 "재고 부족" 배지 + 결제 OUT_OF_STOCK 시 LOW_STOCK 알림톡
# - BULK_MAX: 단일 대량 등록 요청에서 받을 수 있는 최대 키 수 (텍스트/CSV 공통)
VENDING_LOW_STOCK_THRESHOLD=5
VENDING_BULK_MAX=500



# 어시스턴트 AI (DashScope Qwen)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1
DASHSCOPE_MODEL=qwen3.6-plus
ASSISTANT_DAILY_LIMIT=10
ASSISTANT_MAX_INPUT_CHARS=1500
ASSISTANT_MAX_IMAGES=4
ASSISTANT_TIMEOUT_MS=45000
ASSISTANT_ENABLE_THINKING=true
CLCO_PROXY_BASE_URL=https://api-anthropic.com/v1
ASSISTANT_AGENTIC_DISABLED=true
ASSISTANT_KEY_OPERATIONS_DISABLED=true
ASSISTANT_IDENTITY_GUARD=strict
ASSISTANT_INJECTION_FILTER=on

# 리뷰 시스템 (20260528_review_system.sql)
# 결제 후 며칠 뒤부터 리뷰 작성 가능한지
REVIEW_ELIGIBILITY_AFTER_DAYS=3
# 승인 시 자동 지급되는 USD 보상 (관리자 페이지에서 즉석 override 가능)
REVIEW_REWARD_USD=50
# 동일 보상의 KRW 환산. 환율 변동 시 운영자가 수동 갱신.
REVIEW_REWARD_KRW=70000
# 본문 길이 제약. DB 함수 submit_review() 가 동일 값을 강제.
REVIEW_BODY_MIN_LEN=20
REVIEW_BODY_MAX_LEN=1000
